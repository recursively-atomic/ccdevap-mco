                                            View
                                        </button>
                                    </td>
                                </tr>

                                <tr class="border-3 border-bottom-0 border-top border-end-0 border-start-0
                                        border-dark">
                                    <th scope="row"> BK001 </th>
                                    <td> Kyeeona Caesar </td>
                                    <td> 1 </td>
                                    <td> MNL to FNJ </td>
                                    <td> Confirmed </td>

                                    <td>
                                        <button class="btn btn-success btn-sm text-white fw-bolder
                                                    view-reservation">
                                            View
                                        </button>
                                    </td>
                                </tr>

                                <tr class="border-3 border-bottom-0 border-top border-end-0 border-start-0
                                        border-dark">
                                    <th scope="row"> BK002 </th>
                                    <td> Nico Cotoco </td>
                                    <td> 5 </td>
                                    <td> MNL to SIN </td>
                                    <td> Pending </td>

                                    <td>
                                        <button class="btn btn-success btn-sm text-white fw-bolder
                                                    view-reservation">
                                            View
                                        </button>
                                    </td>
                                </tr>

                                <tr class="border-3 border-bottom-0 border-top border-end-0 border-start-0 
                                        border-dark">
                                    <th scope="row"> BK003 </th>
                                    <td> Anthony Namol </td>
                                    <td> 2 </td>
                                    <td> MNL to ICN </td>
                                    <td> Cancelled </td>

                                    <td>
                                        <button class="btn btn-success btn-sm text-white fw-bolder
                                                    view-reservation">
                                            View
                                        </button>
                                    </td>
                                </tr>

                                <tr class="border-3 border-bottom-0 border-top border-end-0 border-start-0
                                        border-dark">
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-lg-8 mb-md-4 mb-sm-4 mb-4 mb-lg-0">
                    <!-- MONTHLY REVENUE CARD -->
                    <div class="card shadow card-hover-md">
                        <h4 class="card-header bg-dark text-secondary fw-bold text-center">
                            Monthly Revenue
                        </h4>

                        <div class="card-body">
                            <div>
                                <div> Jan </div>
                                <div> Feb </div>
                                <div> Mar </div>
                                <div> Apr </div>
                                <div> May </div>
                                <div> Jun </div>
                                <div> Jul </div>
                                <div> Aug </div>
                                <div> Sept </div>
                                <div> Oct </div>
                                <div> Nov </div>
                                <div> Dec </div>
