        </div>
    </div>
</div>

<!-- VIEW RESERVATION MODAL -->
<div class="modal fade" id="view-reservation" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h2 class="modal-title fs-5"></h2>

                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body bg-white text-dark fw-bolder">
                ...
            </div>

            <div class="modal-footer bg-light">
                <button class="btn btn-primary text-white" data-bs-dismiss="modal">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<!-- DASHBOARD TOAST -->
<div class="toast position-fixed bottom-0 start-50 translate-middle-x text-bg-primary-accent text-white z-max p-2 m-3 w-auto"
     id="dashboard-toast">
    <div class="d-flex align-items-center">
        <div class="toast-body text-nowrap">
            Welcome Administrator {{user.firstName}} {{user.lastName}}!
        </div>

        <button class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
</div>

{{> footer}}