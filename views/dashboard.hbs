                                    <th class="bg-dark text-secondary" scope="col">
                                        Route
                                    </th>

                                    <th class="bg-dark text-secondary" scope="col">
                                        Status
                                    </th>

                                    <th class="bg-dark text-secondary" scope="col">
                                        Details
                                    </th>
                                </tr>
                            </thead>

                            <tbody class="table-group-divider">
                                <tr>
                                    <th scope="row"> BK000 </th>
                                    <td> Darryl Ac-ac </td>
                                    <td> 2 </td>
                                    <td> MNL to HND </td>
                                    <td> Confirmed </td>

                                    <td>
                                        <button class="btn btn-success btn-sm text-white fw-bolder
