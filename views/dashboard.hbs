                </div>

                <div class="col-lg-4">
                    <!-- POPULAR DESTONATIONS CARD -->
                    <div class="card shadow card-hover-sm">
                        <h4 class="card-header bg-dark text-secondary fw-bold text-center">
                            Popular Destinations
                        </h4>

                        <div class="card-body">
                            <ul class="list-group text-center">
                                <li class="list-group-item text-dark">
                                    NRT (Tokyo, Narita International Airport)
                                </li>

                                <li class="list-group-item text-dark">
                                    SIN (Singapore, Singapore Changi Airport)
                                </li>

                                <li class="list-group-item text-dark">
