{{>header}}
<div class="container mt-5 mb-5">
        <div class="card d-flex">
            <div class="card-header text-center text-white bg-primary-accent">
                <h2 class="mt-2"> Reservation Management </h2>
            </div>

            <!-- TABLE -->
            <div class="card-body">
                <div class="table-responsive text-nowrap">
                    <table class="table text-center table-hover">
                        <thead class="border-dark border-2">
                            <tr>
                                <th class="text-secondary bg-dark" scope="col">
                                    Booking Reference
                                </th>

                                <th class="text-secondary bg-dark" scope="col">
                                    Passenger Name
                                </th>

                                <th class="text-secondary bg-dark" scope="col">
                                    Flight Route
                                </th>

                                <th class="text-secondary bg-dark" scope="col">
                                    Seat Number
                                </th>

                                <th class="text-secondary bg-dark" scope="col">
                                    Booking Status
                                </th>

                                <th class="text-secondary bg-dark" scope="col">
                                    Details
                                </th>
                            </tr>
                        </thead>

                        <tbody class="table-group-divider">

                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-primary-accent">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 m-3">
                    <h6 class="text-white">
                        Showing 10 Results Out Of 100,000
                    </h6>

                    <div class="d-flex justify-content-center align-items-center flex-wrap gap-3">
                        <button class="btn m-0 btn-success text-white">
                            Add Reservation
                            <!-- This would go to reservations.html -->
                        </button>

                        <!-- PAGINATION -->
                        <nav>
                            <ul class="pagination m-0">
                                <li class="page-item">
                                    <a class="page-link disabled">
                                        <span aria-hidden="true">
                                            < </span>
                                    </a>
                                </li>

                                <li class="page-item"><a class="page-link active"> 1 </a></li>
                                <li class="page-item"><a class="page-link"> ... </a></li>
                                <li class="page-item"><a class="page-link"> 10 </a></li>

                                <li class="page-item">
                                    <a class="page-link">
                                        <span aria-hidden="true"> > </span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- VIEW RESERVATION MODAL -->
    <div class="modal fade" id="view-reservation" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h2 class="modal-title fs-5"> [BOOKING REFERENCE] Details </h2>
                </div>

                <div class="modal-body bg-white fw-bolder text-dark">
                </div>

                <div class="modal-footer bg-light">
                    <button class="btn btn-primary text-white" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>


    <!-- EDIT RESERVATION MODAL -->
    <div class="modal fade" id="edit-reservation" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">
                        Edit Reservation
                    </h5>
                </div>

                <div class="modal-body">
                    <input type="hidden"id="edit-reservation-id">

                    <div class="mb-3">
                        <label class="form-label"> Reservation Status </label>

                        <select
                            class="form-select" id="reservation-status">
                            <option>Pending</option>
                            <option>Paid</option>
                            <option>Cancelled</option>
                            <option>Waitlisted</option>
                            <option>Rescheduled</option>
                        </select>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-success" id="save-reservation-btn">
                        Save Changes
                    </button>

                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- DELETE RESERVATION MODAL -->
    <div class="modal fade" id="delete-reservation" data-bs-backdrop="static">
        <div class="modal-dialog modal-sm modal-dialog-centered text-center">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h2 class="modal-title fs-5"> Are you sure? </h2>
                </div>

                <input type="hidden" id="delete-reservation-id">

                <div class="modal-footer d-flex bg-light">
                    <button class="btn btn-success text-white" data-bs-dismiss="modal">
                        No
                    </button>

                    <button id="confirm-delete-reservation" class="btn btn-danger text-white" data-bs-dismiss="modal">
                        Yes, Delete It
                    </button>
                </div>
                
            </div>
        </div>
    </div>

    <!-- DELETE RESERVATION TOAST -->
    <div class="toast position-fixed bottom-0 start-50 translate-middle-x p-2 m-3 w-auto text-bg-danger text-white"
         id="delete-toast">
        <div class="d-flex align-items-center">
            <div class="text-nowrap toast-body">
                Deleted [BOOKING REFERENCE]!
            </div>

            <button class="me-2 m-auto btn-close btn-close-white" data-bs-dismiss="toast"></button>
        </div>
    </div>

    <div class="toast position-fixed bottom-0 start-50 translate-middle-x p-2 m-3 w-auto text-bg-success text-white"
        id="edit-toast">

        <div class="d-flex align-items-center">
            <div class="toast-body">
                Reservation updated successfully!
            </div>

            <button
                class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast">
            </button>
        </div>
    </div>

    {{>footer}}