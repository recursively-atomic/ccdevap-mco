{{> navigation}}

<div class="container mt-5 mb-5">
    <div class="card d-flex shadow-lg">
        <div class="card-header text-center text-white bg-primary-accent">
            <div class="row my-md-3 mx-0 p-0 align-items-center">
                <!-- SEARCH BAR -->
                <div class="col-lg-6 col-md-12 mb-md-4 mb-lg-0 col-sn-12 my-sm-4 my-4 mt-md-3 mt-lg-0">
                    <div class="input-group">
                        <div class="input-group-text bg-dark border-dark">
                            <i class="text-secondary fa-solid fa-magnifying-glass"></i>
                        </div>

                        <div class="form-floating">
                            <input class="form-control bg-light border-dark border-5 text-black rounded-end-3"
                                   placeholder="">
                            <label for="search"> Search </label>
                        </div>
                    </div>
                </div>

                <!-- SORT BY DROPDOWN -->
                <div class="col-lg-3 col-md-6 mb-md-0 mb-sm-4 mb-4">
                    <div class="dropdown dropdown-center">
                        <button class="btn btn-primary btn-lg text-white dropdown-toggle w-100" type="button"
                                data-bs-toggle="dropdown">
                            Sort By
                            <span id="sort-type"> Price (1-9) </span>
                        </button>

                        <ul class="dropdown-menu bg-dark-subtle text-dark" id="sort-dropdown">
                            <li>
                                <h4 class="dropdown-header"> Sort By </h4>
                            </li>

                            <li class="dropdown-divider"></li>

                            <li value="Price (1-9)">
                                <a class="dropdown-item text-dark active">
                                    <i class="fa-solid fa-arrow-down-1-9"></i> Price
                                </a>
                            </li>

                            <li value="Price (9-1)">
                                <a class="dropdown-item text-dark">
                                    <i class="fa-solid fa-arrow-down-9-1"></i> Price
                                </a>
                            </li>

                            <li class="dropdown-divider"></li>

                            <li value="Departure (1-9)">
                                <a class="dropdown-item text-dark">
                                    <i class="fa-solid fa-arrow-down-9-1"></i> Departure
                                </a>
                            </li>

                            <li value="Departure (9-1)">
                                <a class="dropdown-item text-dark">
                                    <i class="fa-solid fa-arrow-down-9-1"></i> Departure
                                </a>
                            </li>

                            <li class="dropdown-divider"></li>

                            <li value="Duration (1-9)">
                                <a class="dropdown-item text-dark">
                                    <i class="fa-solid fa-arrow-down-1-9"></i> Duration
                                </a>
                            </li>

                            <li value="Duration (9-1)">
                                <a class="dropdown-item text-dark">
                                    <i class="fa-solid fa-arrow-down-9-1"></i> Duration
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- FILTER BY DROPDOWN -->
                <div class="col-lg-3 col-md-6 mb-sm-4 mb-md-0 mb-4">
                    <div class="dropdown dropdown-center">
                        <button class="btn btn-primary btn-lg text-white dropdown-toggle w-100" type="button"
                                data-bs-toggle="dropdown">
                            Filter By
                            <span id="filter-type"> Confirmed </span>
                        </button>

                        <ul class="dropdown-menu bg-dark-subtle text-dark" id="filter-dropdown">
                            <li>
                                <h4 class="dropdown-header"> Filter By </h4>
                            </li>

                            <li class="dropdown-divider"></li>

                            <li value="Confirmed">
                                <a class="dropdown-item text-dark active">
                                    <i class="bi bi-check-circle-fill"></i> Confirmed
                                </a>
                            </li>

                            <li value="Wailisted">
                                <a class="dropdown-item text-dark">
                                    <i class="bi bi-clock-fill"></i> Waitlisted
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body">
            {{> reservationCards}}
        </div>

        <div class="card-footer bg-primary-accent">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 m-3">
                <h6 class="text-white">
                    Showing {{pagination.resultsPerPage}} Results Out Of {{pagination.totalResults}}
                </h6>

                <div class="d-flex justify-content-center align-items-center flex-wrap gap-3">
                    {{> pagination}}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- VIEW RESERVATION MODAL -->
<div class="modal fade" id="view-reservation" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h2 class="modal-title fs-5"></h2>
            </div>

            <div class="modal-body bg-white fw-bolder text-dark"></div>

            <div class="modal-footer bg-light">
                <button class="btn btn-primary text-white" data-bs-dismiss="modal">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<!-- EDIT RESERVATION MODAL -->
<div class="modal fade" id="edit-reservation" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h2 class="modal-title fs-5"></h2>
            </div>

            <div class="modal-body bg-white fw-bolder text-dark">
                <div class="mb-3 d-flex gap-2 justify-content-center">
                    <div class="row w-100 d-flex justify-content-center text-center">
                        {{> seatLegend}}
                    </div>
                </div>

                <div id="seat-map"></div>
            </div>

            <div class="modal-footer d-flex bg-light">
                <button class="btn btn-success text-white" id="save-button">
                    Save Changes
                </button>

                <button class="btn btn-danger text-white" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- EDIT RESERVATION TOAST -->
<div class="toast position-fixed bottom-0 start-50 translate-middle-x p-2 m-3 w-auto text-bg-success text-white z-max"
     id="edit-toast">
    <div class="d-flex align-items-center">
        <div class="text-nowrap toast-body"></div>

        <button class="me-2 m-auto btn-close btn-close-white" data-bs-dismiss="toast"></button>
    </div>
</div>

<!-- CANCEL RESERVATION MODAL -->
<div class="modal fade" id="cancel-reservation" data-bs-backdrop="static">
    <div class="modal-dialog modal-sm modal-dialog-centered text-center">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h2 class="modal-title fs-5"> Are you sure? </h2>
            </div>

            <div class="modal-footer d-flex bg-light">
                <button class="btn btn-success text-white" data-bs-dismiss="modal">
                    No
                </button>

                <button class="btn btn-danger text-white" id="cancel-button">
                    Yes, Cancel It
                </button>
            </div>
        </div>
    </div>
</div>

<!-- CANCEL RESERVATION TOAST -->
<div class="toast position-fixed bottom-0 start-50 translate-middle-x p-2 m-3 w-auto text-bg-danger text-white z-max"
     id="cancel-toast">
    <div class="d-flex align-items-center">
        <div class="text-nowrap toast-body"></div>

        <button class="me-2 m-auto btn-close btn-close-white" data-bs-dismiss="toast"></button>
    </div>
</div>

{{> footer}}