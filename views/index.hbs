{{> navigation}}

<!-- HERO SECTION -->
<div class="carousel slide">
    <div class="carousel-inner">
        <div class="carousel-item active shadow-lg">
            <img class="d-block rounded-3 shadow-lg img-fluid mx-auto" src="https://picsum.photos/1280/720/?blur=5">

            <div class="carousel-caption text-white">
                <h2 class="fw-bolder"> Cebu Atlantic </h2>
                <h4> Explore the sky! </h4>
            </div>
        </div>
    </div>
</div>

<!-- FLIGHT SEARCH QUICK WIDGET -->
<div class="container mb-4">
    <div class="card mt-4 card-hover-sm text-center shadow-lg bg-secondary-accent">
        <h2 class="card-header bg-primary-accent text-white"> In Need Of A Quick Flight? </h2>

        <div class="card-body rounded-bottom bg-secondary-accent">
            <div class="row d-flex align-items-center">

                <div class="col-lg-4 col-md-6 mb-lg-0 mb-md-3 mb-sm-3 mb-3">
                    <div class="input-group">
                        <div class="input-group-text bg-dark border-dark">
                            <i class="text-secondary fa-solid fa-plane-departure"></i>
                        </div>

                        <div class="form-floating">
                            <input type="text"
                                   class="form-control bg-light border-dark border-5 text-black rounded-end-3"
                                   id="origin" placeholder="" list="result">
                            <label class="ms-1" for="origin"> Flight Origin </label>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 mb-lg-0 mb-md-3 mb-sm-3 mb-3">
                    <div class="input-group">
                        <div class="input-group-text bg-dark border-dark">
                            <i class="text-secondary fa-solid fa-plane-arrival"></i>
                        </div>

                        <div class="form-floating">
                            <input type="text"
                                   class="form-control bg-light border-dark border-5 text-black rounded-end-3"
                                   id="destination" placeholder="" list="result">
                            <label class="ms-1" for="destination"> Flight Destination </label>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-12">
                    <button class="btn btn-lg btn-primary w-100 text-white"> Search Flights </button>
                    <!-- This would go to search.html -->
                </div>
            </div>
        </div>

        <datalist id="result"></datalist>
    </div>
</div>

<!-- PROMOTIONAL CAROUSEL -->
<div class="card align-items-center p-3 mb-4 text-white bg-primary-accent rounded-0">
    <h2 class="text-tertiary">
        <i class="fa-solid fa-star fa-rotate-by" style="--fa-rotate-angle: 45deg;"></i>
        The Cebu Atlantic Experience
        <i class="fa-solid fa-star fa-rotate-by" style="--fa-rotate-angle: -45deg;"></i>
    </h2>

    <p class="m-0 p-0 text-white fw-bolder">
        Experience flexible bookings, low fares, and global best safety practices with Cebu Atlantic.
    </p>
</div>

<div class="container mb-4">
    <div class="carousel slide" id="promotional-carousel" data-bs-ride="carousel">
        <div class="carousel-inner rounded-pill shadow-lg">
            <div class="carousel-item active">
                <img class="d-block w-100" src="https://picsum.photos/1280/720?random=1">
            </div>

            <div class="carousel-item">
                <img class="d-block w-100" src="https://picsum.photos/1280/720?random=2">
            </div>

            <div class="carousel-item">
                <img class="d-block w-100" src="https://picsum.photos/1280/720?random=3">
            </div>

            <div class="carousel-item">
                <img class="d-block w-100" src="https://picsum.photos/1280/720?random=4">
            </div>

            <div class="carousel-item">
                <img class="d-block w-100" src="https://picsum.photos/1280/720?random=5">
            </div>
        </div>

        <button class="carousel-control-prev" data-bs-target="#promotional-carousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" data-bs-target="#promotional-carousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</div>

<!-- FLIGHT STATISTICS -->
<div class="card align-items-center p-3 text-white bg-primary-accent rounded-0 fw-bolder">
    <h2 class="text-secondary">
        <i class="fa-solid fa-arrow-up-right-dots"></i>
        Flight Statistics
        <i class="fa-solid fa-arrow-up-right-dots fa-flip-horizontal"></i>
    </h2>
</div>

<div class="container mb-4">
    <div class="row">
        <!-- AVAILABLE FLIGHTS -->
        <div class="card col-lg-4 col-md-6 card-hover-sm mt-lg-4 my-md-3 my-sm-3 my-3 text-center bg-transparent
                 border-0 shadow-none h-100">
            <h2 class="card-header bg-secondary-accent text-tertiary text-center"> Available Flights </h2>

            <div class="card-body d-flex flex-column rounded-bottom shadow-lg bg-tertiary-accent">
                <div class="card bg-white">
                    <div class="card-body pt-3 pb-2">
                        <h2 class="text-danger"> 4 Flights Left </h2>
                    </div>
                </div>

                <hr class="border border-3 border-dark rounded-3 opacity-100">

                <button class="btn btn-lg btn-secondary mx-auto text-white">
                    Book A Flight Now
                    <!-- This would go to booking.html -->
                </button>
            </div>
        </div>

        <!-- ACTIVE BOOKINGS -->
        <div class="card col-lg-4 col-md-6 card-hover-sm mt-lg-4 my-md-3 mb-sm-3 mb-3 text-center bg-transparent
                 border-0 shadow-none h-100">
            <h2 class="card-header bg-secondary-accent text-tertiary text-center"> Active Bookings </h2>

            <div class="card-body d-flex flex-column rounded-bottom shadow-lg bg-tertiary-accent">
                <div class="card bg-white">
                    <div class="card-body pt-3 pb-2">
                        <h2 class="text-success"> 10 Active Bookings </h2>
                    </div>
                </div>

                <hr class="border border-3 border-dark rounded-3 opacity-100">

                <button class="btn btn-lg btn-secondary mt-auto mx-auto text-white">
                    Manage My Reservations
                    <!-- This would go to the travel history tab in profile.html -->
                </button>
            </div>
        </div>

        <!-- POPULAR DESTINATIONS -->
        <div class="card col-lg-4 col-md-12 mt-lg-4 card-hover-sm text-center bg-transparent border-0 shadow-none">
            <h2 class="card-header bg-secondary-accent text-tertiary text-center"> Popular Destinations </h2>

            <div class="card-body rounded-bottom shadow-lg bg-tertiary-accent">
                <div class="card mb-3 bg-white">
                    <div class="card-body pt-3 pb-2">
                        <h2 class="text-black"> From Manila </h2>

                        <hr class="border border-3 rounded-3 border-dark opacity-100">

                        <p class="text-black"> Location, Location, Location, Location, Location, Location </p>
                    </div>
                </div>

                <div class="card mb-3 bg-white">
                    <div class="card-body pt-3 pb-2">
                        <h2 class="text-black"> From Cebu </h2>

                        <hr class="border border-3 rounded-3 border-dark opacity-100">

                        <p class="text-black"> Location, Location, Location, Location, Location, Location </p>
                    </div>
                </div>

                <button class="btn btn-lg btn-secondary text-white">
                    Book A Popular Flight Now
                    <!-- This would go to booking.html -->
                </button>
            </div>
        </div>
    </div>
</div>

{{> footer}}