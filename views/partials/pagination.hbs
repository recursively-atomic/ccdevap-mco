{{#if (gt pagination.totalPages 1)}}
    <nav>
        <ul class="pagination m-0">
            <li class="page-item">
                <a class="page-link {{#if (eq pagination.currentPage 1)}}disabled{{/if}}"
                   href="{{#if (gt pagination.currentPage 1)}}{{pagination.baseUrl}}{{subtract pagination.currentPage 1}}{{else}}#{{/if}}">
                    <span> &laquo; </span>
                </a>
            </li>

            {{#each (range 1 pagination.totalPages)}}
                {{#if (or (eq this 1) (eq this ../pagination.totalPages) (and (gte this (subtract ../pagination.currentPage 1)) (lte this (add ../pagination.currentPage 1))))}}
                    {{#if (eq this ../pagination.currentPage)}}
                        <li class="page-item">
                            <a class="page-link active"> {{this}} </a>
                        </li>
                    {{else}}
                        <li class="page-item">
                            <a class="page-link" href="{{../pagination.baseUrl}}{{this}}"> {{this}} </a>
                        </li>
                    {{/if}}
                {{else}}
                    {{#if (or (eq this (add ../pagination.currentPage 2)) (eq this (subtract ../pagination.currentPage 2)))}}
                        <li class="page-item">
                            <a class="page-link disabled"> … </a>
                        </li>
                    {{/if}}
                {{/if}}
            {{/each}}
            
            <li class="page-item">
                <a class="page-link {{#if (eq pagination.currentPage pagination.totalPages)}}disabled{{/if}}"
                   href="{{#if (lt pagination.currentPage pagination.totalPages)}}{{pagination.baseUrl}}{{add pagination.currentPage 1}}{{else}}#{{/if}}">
                    <span aria-hidden="true"> &raquo; </span>
                </a>
            </li>
        </ul>
    </nav>
{{/if}}